{
  "name": "ides-backend",
  "version": "1.0.0",
  "description": "IDES Backend - Interactive Digital Engagement System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node node_modules/prisma/build/index.js generate && node dist/server.js",
